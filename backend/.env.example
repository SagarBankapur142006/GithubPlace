# Database
DATABASE_URL=postgresql+asyncpg://ideora:ideora@localhost:5432/ideora
SYNC_DATABASE_URL=postgresql://ideora:ideora@localhost:5432/ideora

# GitHub (required for scout pipeline and OAuth login)
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI provider: openai | gemini
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRE_MINUTES=10080

# Stripe (test mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Scout
SCOUT_INTERVAL_HOURS=6
SCOUT_MAX_REPOS_PER_RUN=10
CRAWL_COOLDOWN_HOURS=24
FULFILLMENT_STORAGE_PATH=./fulfillment_packages

# Dev without Postgres (local only)
USE_SQLITE=false
SQLITE_PATH=./ideora.db
