{
  "manifest_version": 3,
  "name": "Ideora AI Code Valuator",
  "version": "1.0",
  "description": "Instantly estimate the valuation, growth potential, tech stack, and expert analysis of any software project or codebase.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://34.224.7.229/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
